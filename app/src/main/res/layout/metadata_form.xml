<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create / Edit Data Package"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="12dp"
            android:gravity="center" />

        <!-- Package Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Package Name *"
            android:textSize="14sp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/metadata_package_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter package name"
            android:inputType="text"
            android:maxLines="1"
            android:layout_marginBottom="12dp" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textSize="14sp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/metadata_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter description"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:maxLines="4"
            android:gravity="top"
            android:layout_marginBottom="12dp" />

        <!-- Author -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Author"
            android:textSize="14sp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/metadata_author"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter author name"
            android:inputType="text"
            android:maxLines="1"
            android:layout_marginBottom="12dp" />

        <!-- Latitude -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Latitude"
            android:textSize="14sp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/metadata_latitude"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 37.123456"
            android:inputType="numberDecimal|numberSigned"
            android:maxLines="1"
            android:layout_marginBottom="12dp"
            android:focusable="false"
            android:clickable="false"
            android:cursorVisible="false"
            android:background="@android:color/transparent" />

        <!-- Longitude -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Longitude"
            android:textSize="14sp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/metadata_longitude"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. -122.123456"
            android:inputType="numberDecimal|numberSigned"
            android:maxLines="1"
            android:layout_marginBottom="20dp"
            android:focusable="false"
            android:clickable="false"
            android:cursorVisible="false"
            android:background="@android:color/transparent" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/metadata_cancel_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/metadata_create_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>