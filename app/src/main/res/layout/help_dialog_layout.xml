<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/popup_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Help"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/heading_yellow"
        android:gravity="center"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="300dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This plugin provides blockchain-based evidence recording functionality.\n\n• Create/Edit Data Package: Create new data packages or modify existing ones.\n\n• Fingerprint Data Package: Hash selected data package and send metadata to blockchain.\n\n• Send Data Package: TBD."
            android:textSize="14sp"
            android:textColor="@color/white"
            android:lineSpacingExtra="4dp"
            android:padding="8dp" />

    </ScrollView>

    <Button
        android:id="@+id/help_exit_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Exit"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:minWidth="100dp"
        style="@style/darkButton" />

</LinearLayout>